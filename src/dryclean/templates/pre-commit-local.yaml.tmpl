repos:
  - repo: https://github.com/pre-commit/mirrors-prettier
    rev: v4.0.0-alpha.8
    hooks:
      - id: prettier
        types_or: [css, html, javascript, json, yaml]
        args: [--config, "/tmp/dryclean/prettierrc.json"]

  - repo: https://github.com/ComPWA/taplo-pre-commit
    rev: v0.9.3
    hooks:
      - id: taplo-format
        args: [--config, "/tmp/dryclean/taplo.toml"]

  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.15.11
    hooks:
      - id: ruff-format
        args: [--config, "/tmp/dryclean/ruff.toml"]
      - id: ruff-check
        args: [--fix, --config, "/tmp/dryclean/ruff.toml"]

  - repo: https://github.com/shellcheck-py/shellcheck-py
    rev: v0.11.0.1
    hooks:
      - id: shellcheck

  - repo: https://github.com/pre-commit/pre-commit-hooks
    rev: v6.0.0
    hooks:
      - id: trailing-whitespace
      - id: end-of-file-fixer
      - id: check-json
      - id: check-toml
      - id: check-yaml
      - id: check-merge-conflict
      - id: no-commit-to-branch
        args: [--branch, main]

  - repo: local
    hooks:
      - id: stylelint
        name: stylelint
        entry: sh -c 'NODE_PATH="$(dirname "$(command -v stylelint)")/../lib/node_modules" exec stylelint "$@"' --
        language: node
        types: [css]
        args: [--config, "/tmp/dryclean/stylelintrc.json"]
        additional_dependencies: ["stylelint", "stylelint-declaration-strict-value"]
      - id: htmlhint
        name: htmlhint
        entry: htmlhint
        language: node
        types: [html]
        args: [--config, "/tmp/dryclean/htmlhintrc.json"]
        additional_dependencies: ["htmlhint"]
      - id: eslint
        name: eslint
        entry: sh -c 'NODE_PATH="$(dirname "$(command -v eslint)")/../lib/node_modules" exec eslint "$@"' --
        language: node
        types: [javascript]
        args: [--config, "/tmp/dryclean/eslint.config.cjs"]
        additional_dependencies: ["eslint", "eslint-plugin-import"]
      - id: check-comment-density-css
        name: check comment density (css)
        entry: dryclean check css check_comment_density
        language: system
        types: [css]
      - id: check-comment-period-css
        name: check comment period (css)
        entry: dryclean check css check_comment_period
        language: system
        types: [css]
      - id: check-inline-comments-css
        name: check inline comments (css)
        entry: dryclean check css check_inline_comments
        language: system
        types: [css]
      - id: check-kebab-case-filename-css
        name: check kebab case filename (css)
        entry: dryclean check css check_kebab_case_filename
        language: system
        types: [css]
      - id: check-section-dividers-css
        name: check section dividers (css)
        entry: dryclean check css check_section_dividers
        language: system
        types: [css]
      - id: check-comment-density-html
        name: check comment density (html)
        entry: dryclean check html check_comment_density
        language: system
        types: [html]
      - id: check-comment-period-html
        name: check comment period (html)
        entry: dryclean check html check_comment_period
        language: system
        types: [html]
      - id: check-data-attribute-naming-html
        name: check data attribute naming (html)
        entry: dryclean check html check_data_attribute_naming
        language: system
        types: [html]
      - id: check-deprecated-elements-html
        name: check deprecated elements (html)
        entry: dryclean check html check_deprecated_elements
        language: system
        types: [html]
      - id: check-inline-comments-html
        name: check inline comments (html)
        entry: dryclean check html check_inline_comments
        language: system
        types: [html]
      - id: check-kebab-case-filename-html
        name: check kebab case filename (html)
        entry: dryclean check html check_kebab_case_filename
        language: system
        types: [html]
      - id: check-section-dividers-html
        name: check section dividers (html)
        entry: dryclean check html check_section_dividers
        language: system
        types: [html]
      - id: check-comment-density-js
        name: check comment density (javascript)
        entry: dryclean check javascript check_comment_density
        language: system
        types: [javascript]
      - id: check-comment-period-js
        name: check comment period (javascript)
        entry: dryclean check javascript check_comment_period
        language: system
        types: [javascript]
      - id: check-constant-placement-js
        name: check constant placement (javascript)
        entry: dryclean check javascript check_constant_placement
        language: system
        types: [javascript]
      - id: check-function-length-js
        name: check function length (javascript)
        entry: dryclean check javascript check_function_length
        language: system
        types: [javascript]
      - id: check-inline-comments-js
        name: check inline comments (javascript)
        entry: dryclean check javascript check_inline_comments
        language: system
        types: [javascript]
      - id: check-kebab-case-filename-js
        name: check kebab case filename (javascript)
        entry: dryclean check javascript check_kebab_case_filename
        language: system
        types: [javascript]
      - id: check-section-dividers-js
        name: check section dividers (javascript)
        entry: dryclean check javascript check_section_dividers
        language: system
        types: [javascript]
      - id: check-argument-count-py
        name: check argument count (python)
        entry: dryclean check python check_argument_count
        language: system
        types: [python]
      - id: check-comment-density-py
        name: check comment density (python)
        entry: dryclean check python check_comment_density
        language: system
        types: [python]
      - id: check-comment-period-py
        name: check comment period (python)
        entry: dryclean check python check_comment_period
        language: system
        types: [python]
      - id: check-constant-placement-py
        name: check constant placement (python)
        entry: dryclean check python check_constant_placement
        language: system
        types: [python]
      - id: check-docstring-blocks-py
        name: check docstring blocks (python)
        entry: dryclean check python check_docstring_blocks
        language: system
        types: [python]
      - id: check-exception-location-py
        name: check exception location (python)
        entry: dryclean check python check_exception_location
        language: system
        types: [python]
      - id: check-function-length-py
        name: check function length (python)
        entry: dryclean check python check_function_length
        language: system
        types: [python]
      - id: check-inline-comments-py
        name: check inline comments (python)
        entry: dryclean check python check_inline_comments
        language: system
        types: [python]
      - id: check-internal-docstring-py
        name: check internal docstring (python)
        entry: dryclean check python check_internal_docstring
        language: system
        types: [python]
      - id: check-section-dividers-py
        name: check section dividers (python)
        entry: dryclean check python check_section_dividers
        language: system
        types: [python]
      - id: check-snake-case-filename-py
        name: check snake case filename (python)
        entry: dryclean check python check_snake_case_filename
        language: system
        types: [python]
        exclude: '(^|/)__[a-z]+__\.py$'
      - id: check-comment-density-sh
        name: check comment density (shell)
        entry: dryclean check shell check_comment_density
        language: system
        types: [bash]
      - id: check-comment-period-sh
        name: check comment period (shell)
        entry: dryclean check shell check_comment_period
        language: system
        types: [bash]
      - id: check-executable-permission-sh
        name: check executable permission (shell)
        entry: dryclean check shell check_executable_permission
        language: system
        types: [bash]
      - id: check-inline-comments-sh
        name: check inline comments (shell)
        entry: dryclean check shell check_inline_comments
        language: system
        types: [bash]
      - id: check-kebab-case-filename-sh
        name: check kebab case filename (shell)
        entry: dryclean check shell check_kebab_case_filename
        language: system
        types: [bash]
      - id: check-section-dividers-sh
        name: check section dividers (shell)
        entry: dryclean check shell check_section_dividers
        language: system
        types: [bash]
      - id: check-shebang-sh
        name: check shebang (shell)
        entry: dryclean check shell check_shebang
        language: system
        types: [bash]
      - id: check-strict-mode-sh
        name: check strict mode (shell)
        entry: dryclean check shell check_strict_mode
        language: system
        types: [bash]
